{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/local-api/canvas/outline/work-outline.schema.json",
  "schema_version": 1,
  "title": "Nexus WorkOutline",
  "description": "Canonical read model for the Work outline + timeline (V1.72). Exposes the outline_revision and structured metadata needed by the Canvas Outline+Timeline surface.",
  "type": "object",
  "required": ["work_id", "outline_revision", "volumes", "timeline_events", "foreshadows", "updated_at"],
  "properties": {
    "work_id": { "type": "string" },
    "outline_revision": {
      "type": "integer",
      "minimum": 0,
      "description": "Current canonical revision of the Work outline frontmatter."
    },
    "volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["volume_id", "label", "chapter_ids"],
        "properties": {
          "volume_id": { "type": "integer", "minimum": 1 },
          "label": { "type": "string" },
          "chapter_ids": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 }
          }
        },
        "additionalProperties": false
      },
      "description": "Ordered list of volumes, each holding an ordered list of chapter ids."
    },
    "timeline_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "title"],
        "properties": {
          "event_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "realizes_chapter_id": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "description": "Timeline events scheduled across chapters."
    },
    "foreshadows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_event_id", "target_event_id"],
        "properties": {
          "source_event_id": { "type": "string" },
          "target_event_id": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "Foreshadow edges linking a source event to a later resolving event."
    },
    "updated_at": { "type": "string", "description": "ISO 8601 timestamp of the last outline write." }
  },
  "additionalProperties": false
}
