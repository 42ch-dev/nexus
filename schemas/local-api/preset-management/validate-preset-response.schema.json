{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/local-api/preset-management/validate-preset-response.schema.json",
  "schema_version": 1,
  "title": "Nexus ValidatePresetResponse",
  "description": "Response for POST /v1/local/presets:validate — validation result with structured errors and warnings.",
  "type": "object",
  "required": ["valid", "errors"],
  "properties": {
    "valid": { "type": "boolean" },
    "id": { "type": "string" },
    "version": { "type": "integer" },
    "state_count": { "type": "integer" },
    "errors": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
