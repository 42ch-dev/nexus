{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/local-api/schedule/core-context-response.schema.json",
  "schema_version": 1,
  "title": "Nexus CoreContextResponse",
  "description": "Response for GET /v1/local/orchestration/schedules/{schedule_id}/core-context.",
  "type": "object",
  "required": ["version", "payload_kind", "content", "derivation_kind", "created_at"],
  "properties": {
    "version": { "type": "integer", "description": "Core context version number." },
    "payload_kind": { "type": "string", "description": "Payload type (text or struct)." },
    "content": { "description": "Core context content (text or structured JSON)." },
    "derivation_kind": { "type": "string", "description": "How this version was derived (seed, user_edit, preset_hook, llm_summarize, preset_seed_expansion)." },
    "created_at": { "type": "string", "description": "ISO-8601 creation timestamp." }
  },
  "additionalProperties": false
}
