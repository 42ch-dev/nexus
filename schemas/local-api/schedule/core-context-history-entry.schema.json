{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/local-api/schedule/core-context-history-entry.schema.json",
  "schema_version": 1,
  "title": "Nexus CoreContextHistoryEntry",
  "description": "Single entry in core context version history.",
  "type": "object",
  "required": ["version", "payload_kind", "derivation_kind", "created_at"],
  "properties": {
    "version": { "type": "integer", "description": "Core context version number." },
    "payload_kind": { "type": "string", "description": "Payload type (text or struct)." },
    "content": { "description": "Core context content at this version." },
    "derivation_kind": { "type": "string", "description": "How this version was derived." },
    "created_at": { "type": "string", "description": "ISO-8601 creation timestamp." }
  },
  "additionalProperties": false
}
