{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/local-api/works/chapters/chapter-outline.schema.json",
  "schema_version": 1,
  "title": "Nexus ChapterOutline",
  "description": "Response body for GET/PUT /v1/local/works/{work_id}/chapters/{n}/outline (V1.65 P0).",
  "type": "object",
  "required": ["work_id", "chapter", "volume", "outline_path", "content", "updated_at"],
  "properties": {
    "work_id": { "type": "string" },
    "chapter": { "type": "integer", "minimum": 1 },
    "volume": { "type": "integer", "minimum": 1 },
    "outline_path": { "type": "string" },
    "content": { "type": "string", "description": "Full outline markdown content. UTF-8." },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
