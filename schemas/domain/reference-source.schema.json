{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.42ch.io/schemas/domain/reference-source.schema.json",
  "schema_version": 1,
  "title": "Nexus ReferenceSource",
  "description": "ReferenceSource - local-only registration of research/reference sources. Does NOT sync to platform; shared excerpts go through MemoryItem(memory_kind=research_material). Aligned with data-model-v1.md §5.9A.",
  "type": "object",
  "required": ["schema_version", "reference_source_id", "workspace_id", "source_type", "uri", "title", "scan_status", "created_at"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "reference_source_id": {
      "type": "string",
      "pattern": "^ref_[a-zA-Z0-9]+$",
      "description": "Unique ReferenceSource identifier"
    },
    "workspace_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/WorkspaceId",
      "description": "Workspace this reference belongs to"
    },
    "source_type": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/ReferenceSourceType",
      "description": "Type of reference source"
    },
    "uri": {
      "type": "string",
      "description": "File path or URL to the reference"
    },
    "title": {
      "type": "string",
      "description": "Display title of the reference"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Classification tags"
    },
    "content_hash": {
      "type": "string",
      "description": "Content hash in sha256:xxx format"
    },
    "scan_status": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/ScanStatus",
      "description": "Scan processing status"
    },
    "created_at": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Reference registration timestamp"
    },
    "updated_at": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Last update timestamp"
    }
  },
  "additionalProperties": false
}
