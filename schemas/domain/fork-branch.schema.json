{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.42ch.io/schemas/domain/fork-branch.schema.json",
  "schema_version": 1,
  "title": "Nexus ForkBranch",
  "description": "ForkBranch - describes a world branch forked from a parent world at a specific event. Aligned with data-model-v1.md §5.7.",
  "type": "object",
  "required": ["schema_version", "fork_branch_id", "world_id", "parent_world_id", "parent_branch_id", "forked_from_event_id", "status", "verification_status", "created_by_creator_id", "created_at"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "fork_branch_id": {
      "type": "string",
      "pattern": "^fbk_[a-zA-Z0-9]+$",
      "description": "Unique ForkBranch identifier"
    },
    "world_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/WorldId",
      "description": "Child world ID (the fork)"
    },
    "parent_world_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/WorldId",
      "description": "Parent world ID (the source)"
    },
    "parent_branch_id": {
      "type": "string",
      "pattern": "^fbk_[a-zA-Z0-9]+$",
      "description": "Parent fork branch ID"
    },
    "forked_from_event_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/TimelineEventId",
      "description": "TimelineEvent where the fork occurred"
    },
    "status": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/ForkBranchStatus",
      "description": "ForkBranch status"
    },
    "verification_status": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/VerificationStatus",
      "description": "ForkBranch verification status"
    },
    "created_by_creator_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/CreatorId",
      "description": "Creator who initiated the fork"
    },
    "created_at": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Fork creation timestamp"
    }
  },
  "additionalProperties": false
}
