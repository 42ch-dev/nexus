{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.42ch.io/schemas/domain/agent-profile.schema.json",
  "schema_version": 1,
  "title": "AgentProfile",
  "description": "Configuration for an ACP agent in a workspace. Aligned with data-model-v1.md §5.15.",
  "type": "object",
  "required": ["schema_version", "agent_profile_id", "workspace_id", "profile_kind", "selection_mode", "status"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version"
    },
    "agent_profile_id": {
      "type": "string",
      "description": "Unique profile identifier"
    },
    "workspace_id": {
      "type": "string",
      "description": "Workspace this profile belongs to"
    },
    "profile_kind": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/ProfileKind",
      "description": "Kind of agent profile (local or platform-hosted)"
    },
    "selection_mode": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/SelectionMode",
      "description": "How agent is selected"
    },
    "registry_agent_id": {
      "type": "string",
      "description": "Agent ID from ACP Registry (if selection_mode=registry)"
    },
    "launch_command": {
      "type": ["string", "null"],
      "description": "Command to launch agent (if selection_mode=manual_command or manual_remote)"
    },
    "transport": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Transport",
      "description": "Transport method for agent communication"
    },
    "default_output_manuscript": {
      "type": "boolean",
      "description": "Default manuscript output for this profile"
    },
    "protocol_version": {
      "type": "integer",
      "description": "ACP protocol version (e.g., 1)"
    },
    "status": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/AgentProfileStatus",
      "description": "Profile status"
    },
    "created_at": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Last update timestamp"
    }
  },
  "additionalProperties": false
}