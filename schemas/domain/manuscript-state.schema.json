{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.42ch.io/schemas/domain/manuscript-state.schema.json",
  "schema_version": 1,
  "title": "Nexus ManuscriptState",
  "description": "ManuscriptState - local-only manuscript phase machine tracking creation progression. Platform may receive manuscript_phase as bundle metadata but does not own this aggregate in V1.0. Aligned with data-model-v1.md §5.9B.",
  "type": "object",
  "required": ["schema_version", "manuscript_state_id", "workspace_id", "world_id", "creator_id", "manuscript_phase", "updated_at"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "manuscript_state_id": {
      "type": "string",
      "pattern": "^mss_[a-zA-Z0-9]+$",
      "description": "Unique ManuscriptState identifier"
    },
    "workspace_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/WorkspaceId",
      "description": "Workspace this state belongs to"
    },
    "world_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/WorldId",
      "description": "World this manuscript is for"
    },
    "creator_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/CreatorId",
      "description": "Creator working on this manuscript"
    },
    "manuscript_phase": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/ManuscriptPhase",
      "description": "Current manuscript lifecycle phase"
    },
    "active_manifest_id": {
      "type": "string",
      "pattern": "^stm_[a-zA-Z0-9]+$",
      "description": "Currently active StoryManifest ID"
    },
    "last_confirmed_delta_sequence": {
      "type": "integer",
      "minimum": 0,
      "description": "Last confirmed delta sequence for conflict detection"
    },
    "updated_at": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Last state update timestamp"
    }
  },
  "additionalProperties": false
}
