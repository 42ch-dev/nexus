{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/domain/user.schema.json",
  "schema_version": 1,
  "title": "Nexus User Entity",
  "description": "End-user account for authentication and platform identity. Aligned with data-model-v1.md §5.1.",
  "type": "object",
  "required": [
    "schema_version",
    "user_id",
    "username",
    "email",
    "display_name",
    "account_status",
    "subscription_tier",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "user_id": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/UserId",
      "description": "Unique user identifier"
    },
    "username": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Unique login handle"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 255,
      "description": "Primary email address"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable display name"
    },
    "account_status": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/AccountStatus",
      "description": "Account lifecycle state"
    },
    "subscription_tier": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/SubscriptionTier",
      "description": "Subscription / entitlements tier"
    },
    "created_at": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Account creation time"
    },
    "updated_at": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "Last profile or status update"
    }
  },
  "additionalProperties": false
}
