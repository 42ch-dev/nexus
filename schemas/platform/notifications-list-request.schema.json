{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/platform/notifications-list-request.schema.json",
  "schema_version": 1,
  "title": "Nexus NotificationsListRequest",
  "description": "Request body for listing notifications (platform plan 20).",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "cursor": {
      "type": "string"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "unread_only": {
      "type": "boolean",
      "description": "When true, only unread rows"
    }
  },
  "additionalProperties": false
}
