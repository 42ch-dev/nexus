{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.42ch.io/schemas/platform/explore-hit.schema.json",
  "schema_version": 1,
  "title": "Nexus ExploreHit",
  "description": "Single browse/search result row for Explore read APIs (platform contract; plan 16 slice).",
  "type": "object",
  "required": ["hit_type", "entity_id", "title"],
  "properties": {
    "hit_type": {
      "type": "string",
      "enum": ["world", "creator", "manuscript", "other"],
      "description": "Discriminator for entity_id interpretation"
    },
    "entity_id": {
      "type": "string",
      "description": "Platform entity id (e.g. wld_*, ctr_*, stm_*)"
    },
    "title": {
      "type": "string",
      "description": "Primary display label"
    },
    "subtitle": {
      "type": "string",
      "description": "Secondary line (e.g. persona snippet)"
    },
    "visibility": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/Visibility",
      "description": "Effective visibility when exposed by Explore"
    }
  },
  "additionalProperties": false
}
