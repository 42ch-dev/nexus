{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/platform/http-bff/publish-story-response.schema.json",
  "schema_version": 1,
  "title": "Nexus PublishStoryResponse",
  "description": "Response body for POST /v1/publish/story.",
  "type": "object",
  "required": ["schema_version", "outcome"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "outcome": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/PublishStoryOutcome",
      "description": "Publish result"
    },
    "message": {
      "type": "string",
      "description": "Human-readable detail (validation errors, server notes)"
    },
    "published_artifact_id": {
      "type": "string",
      "description": "Platform artifact id when published"
    },
    "error_code": {
      "type": "string",
      "description": "Stable machine code when outcome is rejected or invalid_state"
    }
  },
  "additionalProperties": false
}
