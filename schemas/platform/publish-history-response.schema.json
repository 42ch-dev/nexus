{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/platform/publish-history-response.schema.json",
  "schema_version": 1,
  "title": "Nexus PublishHistoryResponse",
  "description": "Response body for POST /v1/publish/history.",
  "type": "object",
  "required": ["schema_version", "entries", "has_more"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "https://nexus42.invalid/schemas/platform/publish-history-entry.schema.json"
      }
    },
    "next_cursor": {
      "type": "string",
      "description": "Opaque cursor for the next page; omit when not available"
    },
    "has_more": {
      "type": "boolean",
      "description": "True when additional pages may exist"
    }
  },
  "additionalProperties": false
}
