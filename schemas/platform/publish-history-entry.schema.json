{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/platform/publish-history-entry.schema.json",
  "schema_version": 1,
  "title": "Nexus PublishHistoryEntry",
  "description": "Single publish history row (platform Publish API).",
  "type": "object",
  "required": ["occurred_at", "outcome"],
  "properties": {
    "occurred_at": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/Timestamp",
      "description": "When the publish attempt was recorded"
    },
    "outcome": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/PublishStoryOutcome"
    },
    "story_manifest_id": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/StoryManifestId"
    },
    "published_artifact_id": {
      "type": "string"
    },
    "message": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
