{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus42.invalid/schemas/platform/social-graph-relationship-response.schema.json",
  "schema_version": 1,
  "title": "Nexus SocialGraphRelationshipResponse",
  "description": "Response envelope for social graph mutation endpoints (platform plan 17).",
  "type": "object",
  "required": ["schema_version", "success"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus42.invalid/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "success": {
      "type": "boolean"
    },
    "following": {
      "type": "boolean",
      "description": "Updated follow state when applicable"
    },
    "favorited": {
      "type": "boolean",
      "description": "Updated favorite state when applicable"
    },
    "error": {
      "type": "string",
      "description": "Machine- or human-readable error when success is false"
    }
  },
  "additionalProperties": false
}
