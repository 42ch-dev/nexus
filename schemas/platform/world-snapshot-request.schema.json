{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.42ch.io/schemas/platform/world-snapshot-request.schema.json",
  "schema_version": 1,
  "title": "Nexus WorldSnapshotRequest",
  "description": "Request body for POST /v1/worlds/snapshot — capture a read-only snapshot cursor for a world (platform client contract).",
  "type": "object",
  "required": ["schema_version", "world_id"],
  "properties": {
    "schema_version": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/SchemaVersion"
    },
    "world_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/WorldId",
      "description": "World to snapshot"
    },
    "at_event_id": {
      "$ref": "https://nexus.42ch.io/schemas/common/common.schema.json#/definitions/TimelineEventId",
      "description": "Optional anchor event; when omitted, platform uses latest head for the world"
    }
  },
  "additionalProperties": false
}
